---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import PostHog from "../components/posthog.astro";
import { SITE } from "../lib/site";
import { faqs } from "../data/faq";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.ogImage,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.name}`;

const structuredData = noindex
  ? []
  : [
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: SITE.name,
        url: SITE.url,
        description: SITE.description,
        inLanguage: "en-US",
      },
      {
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Mitch McConnell",
        jobTitle: "United States Senator",
        affiliation: {
          "@type": "GovernmentOrganization",
          name: "United States Senate",
        },
        sameAs: [
          "https://en.wikipedia.org/wiki/Mitch_McConnell",
          "https://www.wikidata.org/wiki/Q355522",
          "https://www.congress.gov/member/mitch-mcconnell/M000355",
        ],
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((faq) => ({
          "@type": "Question",
          name: faq.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
          },
        })),
      },
    ];
---

<!doctype html>
<html lang="en" data-site-theme="default">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}
    <link rel="canonical" href={canonicalURL} />

    <title>{pageTitle}</title>

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Official portrait of Senator Mitch McConnell" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Official portrait of Senator Mitch McConnell" />

    <meta name="theme-color" content="#0a3161" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500&display=swap"
      rel="stylesheet"
    />

    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <PostHog />
    <ClientRouter />
    <script is:inline>
      (function () {
        var pref = localStorage.getItem("themePreference");
        var alive = true;
        var theme = "default";
        if (pref === "happyNow") theme = alive ? "celebration" : "memorial";
        else if (pref === "happyLater") theme = alive ? "memorial" : "celebration";
        document.documentElement.dataset.siteTheme = theme;
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
