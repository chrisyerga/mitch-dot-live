---
import { BLOG_ENABLED } from "../../lib/blogConfig";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogShell from "../../components/BlogShell.astro";
import BlogHomeCta from "../../components/BlogHomeCta.astro";
import { getBlogIndexPosts, formatBlogDate } from "../../lib/blog";
import { getTagPillStyle } from "../../lib/tagPill";

if (!BLOG_ENABLED) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

const posts = await getBlogIndexPosts();
---

<BaseLayout
  title="Blog"
  description="Articles about Senator Mitch McConnell, Senate leadership, and how this live status tracker works."
>
  <BlogShell activeNav="blog">
    <BlogHomeCta />

    <section class="blog-hero">
      <p class="blog-kicker">Editorial</p>
      <h1 class="blog-title">Blog</h1>
      <p class="blog-lede">
        Updates and information from the site's editorial team
      </p>
      <div class="blog-meta-row">
        <a href="/blog/rss.xml" class="blog-rss-link">RSS feed</a>
      </div>
    </section>

    {
      posts.length === 0 ? (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="blog-index-list">
          {posts.map((post) => (
            <li class="blog-index-card">
              <a href={`/blog/${post.slug}/`} class="blog-index-link">
                <span class="blog-index-date">{formatBlogDate(post.pubDate)}</span>
                <span class="blog-index-title">{post.title}</span>
                <span class="blog-index-description">{post.description}</span>
              </a>
              {post.tags && post.tags.length > 0 && (
                <ul class="blog-index-tags" aria-label="Tags">
                  {post.tags.map((tag) => {
                    const pill = getTagPillStyle(tag);
                    return (
                      <li
                        class="blog-tag-pill"
                        style={{
                          backgroundColor: pill.backgroundColor,
                          color: pill.color,
                        }}
                      >
                        {tag}
                      </li>
                    );
                  })}
                </ul>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </BlogShell>
</BaseLayout>
